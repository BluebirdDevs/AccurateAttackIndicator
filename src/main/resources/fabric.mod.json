{
  "schemaVersion": 1,
  "id": "aai",
  "version": "${version}",
  "name": "Accurate Attack Indicator",
  "description": "Shows the visual cooldown when it gets silently reset. Visualizes MC-118740",
  "authors": ["BluebirdDevs"],
  "contact": {
    "sources": "https://github.com/BluebirdDevs/AccurateAttackIndicator",
    "homepage": "https://modrinth.com/project/AoSJ2hG0",
    "issues": "https://github.com/BluebirdDevs/AccurateAttackIndicator/issues"
  },
  "license": "All-Rights-Reserved",
  "icon": "assets/aai/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "bluebird.aai.client.AAIClient"
    ]
  },
  "mixins": [
    {
      "config": "aai.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": ">=${minecraft_version}"
  }
}
